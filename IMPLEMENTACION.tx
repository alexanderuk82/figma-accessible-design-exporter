5. Ejemplo de componente: Modal
typescriptCopy// src/ui/components/modal.ts
export function showModal({
  title,
  content,
  onConfirm,
  onCancel,
  showCancel = true
}) {
  // Crear elemento del modal
  const modalElement = document.createElement('div');
  modalElement.className = 'modal';
  
  modalElement.innerHTML = `
    <div class="modal-content">
      <h2 class="modal-title">${title}</h2>
      <div class="modal-body">
        ${content}
      </div>
      <div class="modal-footer">
        ${showCancel ? '<button class="button button-secondary modal-cancel">Cancel</button>' : ''}
        <button class="button button-primary modal-confirm">Confirm</button>
      </div>
    </div>
  `;
  
  // Añadir al DOM
  document.body.appendChild(modalElement);
  
  // Configurar eventos
  const confirmBtn = modalElement.querySelector('.modal-confirm');
  confirmBtn.addEventListener('click', () => {
    if (onConfirm) {
      onConfirm(modalElement);
    }
    closeModal(modalElement);
  });
  
  if (showCancel) {
    const cancelBtn = modalElement.querySelector('.modal-cancel');
    cancelBtn.addEventListener('click', () => {
      if (onCancel) {
        onCancel();
      }
      closeModal(modalElement);
    });
  }
  
  return modalElement;
}

function closeModal(modalElement) {
  modalElement.classList.add('modal-closing');
  setTimeout(() => {
    document.body.removeChild(modalElement);
  }, 300); // Duración de la animación
}
6. Ejemplo de parseNode (para extraer datos de Figma)
typescriptCopy// src/main/node-parser.ts
export function parseNode(node) {
  // Estructura base para almacenar datos
  const nodeData = {
    id: node.id,
    name: node.name,
    type: node.type,
    children: [],
    properties: {
      styles: {},
      texts: [],
      fills: [],
      effects: []
    }
  };
  
  // Extraer datos según el tipo de nodo
  switch (node.type) {
    case "FRAME":
    case "GROUP":
    case "COMPONENT":
    case "COMPONENT_SET":
    case "INSTANCE":
      // Procesar elementos contenedores
      parseContainerNode(node, nodeData);
      break;
      
    case "TEXT":
      // Procesar nodo de texto
      parseTextNode(node, nodeData);
      break;
      
    case "RECTANGLE":
    case "ELLIPSE":
    case "POLYGON":
    case "STAR":
    case "LINE":
    case "VECTOR":
      // Procesar nodos de forma
      parseShapeNode(node, nodeData);
      break;
      
    // Otros tipos...
  }
  
  return nodeData;
}

function parseContainerNode(node, nodeData) {
  // Extraer estilos del contenedor
  if ("layoutMode" in node) {
    // Auto Layout
    nodeData.properties.styles.layout = {
      mode: node.layoutMode,
      direction: node.primaryAxisAlignItems,
      spacing: node.itemSpacing,
      padding: {
        top: node.paddingTop,
        right: node.paddingRight,
        bottom: node.paddingBottom,
        left: node.paddingLeft
      }
    };
  }
  
  // Extraer restricciones y tamaño
  nodeData.properties.styles.constraints = {
    horizontal: node.constraints?.horizontal,
    vertical: node.constraints?.vertical
  };
  
  nodeData.properties.styles.size = {
    width: node.width,
    height: node.height
  };
  
  // Procesar hijos
  if ("children" in node) {
    node.children.forEach(child => {
      nodeData.children.push(parseNode(child));
    });
  }
}

function parseTextNode(node, nodeData) {
  // Extraer contenido de texto
  nodeData.properties.texts.push({
    content: node.characters,
    style: {
      fontFamily: node.fontName?.family,
      fontWeight: node.fontName?.style,
      fontSize: node.fontSize,
      letterSpacing: node.letterSpacing,
      lineHeight: node.lineHeight,
      textCase: node.textCase,
      textDecoration: node.textDecoration
    }
  });
  
  // Extraer rellenos para el color del texto
  if (node.fills) {
    node.fills.forEach(fill => {
      if (fill.type === "SOLID" && fill.visible !== false) {
        nodeData.properties.fills.push({
          type: "color",
          color: {
            r: fill.color.r,
            g: fill.color.g,
            b: fill.color.b,
            a: fill.opacity ?? 1
          }
        });
      }
    });
  }
}

function parseShapeNode(node, nodeData) {
  // Extraer rellenos
  if (node.fills) {
    node.fills.forEach(fill => {
      if (fill.visible === false) return;
      
      if (fill.type === "SOLID") {
        nodeData.properties.fills.push({
          type: "color",
          color: {
            r: fill.color.r,
            g: fill.color.g,
            b: fill.color.b,
            a: fill.opacity ?? 1
          }
        });
      } else if (fill.type === "IMAGE") {
        nodeData.properties.fills.push({
          type: "image",
          imageHash: fill.imageHash
        });
      }
      // Otros tipos de relleno...
    });
  }
  
  // Extraer bordes
  if (node.strokes && node.strokes.length > 0) {
    nodeData.properties.styles.border = {
      weight: node.strokeWeight,
      align: node.strokeAlign,
      strokes: node.strokes.map(stroke => ({
        type: stroke.type,
        color: stroke.type === "SOLID" ? {
          r: stroke.color.r,
          g: stroke.color.g,
          b: stroke.color.b,
          a: stroke.opacity ?? 1
        } : null
      }))
    };
  }
  
  // Extraer efectos (sombras, etc.)
  if (node.effects) {
    node.effects.forEach(effect => {
      if (effect.visible === false) return;
      
      if (effect.type === "DROP_SHADOW") {
        nodeData.properties.effects.push({
          type: "shadow",
          offset: {
            x: effect.offset.x,
            y: effect.offset.y
          },
          radius: effect.radius,
          color: {
            r: effect.color.r,
            g: effect.color.g,
            b: effect.color.b,
            a: effect.opacity ?? 1
          }
        });
      }
      // Otros tipos de efectos...
    });
  }
}
Este es un ejemplo básico de cómo podría estructurarse e implementarse el plugin. Muestra la organización de archivos, la separación de estilos, y ejemplos concretos de cómo funcionaría la comunicación entre el código principal y la UI, así como el procesamiento de los nodos de Figma.