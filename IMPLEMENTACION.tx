  <div id="app">
    <!-- El contenido se insertará dinámicamente -->
  </div>
  <script src="ui.js"></script>
</body>
</html>
3. ui.ts (Lógica de la UI)
typescriptCopy// src/ui/ui.ts
import { baseStyles } from './styles/base';
import { buttonStyles } from './styles/buttons';
import { modalStyles } from './styles/modal';
import { stepsStyles } from './styles/steps';
import { previewStyles } from './styles/preview';

import { initSteps } from './components/steps';
import { showModal } from './components/modal';
import { renderPreview } from './components/preview';
import { initExportPanel } from './components/export-panel';

// Combinar todos los estilos
const allStyles = `
  ${baseStyles}
  ${buttonStyles}
  ${modalStyles}
  ${stepsStyles}
  ${previewStyles}
`;

// Inicializar la UI cuando el DOM esté listo
document.addEventListener('DOMContentLoaded', () => {
  // Insertar estilos
  const styleSheet = document.createElement('style');
  styleSheet.textContent = allStyles;
  document.head.appendChild(styleSheet);
  
  // Crear estructura inicial
  const app = document.getElementById('app');
  app.innerHTML = `
    <div class="container">
      <h1>Accessible Design Exporter</h1>
      <p>Export your Figma designs as accessible, semantic code.</p>
      
      <div class="steps-container" id="steps-container"></div>
      
      <div class="content-area">
        <div class="step-content" id="step-select">
          <button id="select-frame-btn" class="button button-primary">
            Select this frame
          </button>
        </div>
        
        <div class="step-content hidden" id="step-configure">
          <!-- Se llenará dinámicamente -->
        </div>
        
        <div class="step-content hidden" id="step-preview">
          <!-- Se llenará dinámicamente -->
        </div>
        
        <div class="step-content hidden" id="step-export">
          <!-- Se llenará dinámicamente -->
        </div>
      </div>
    </div>
  `;
  
  // Inicializar componentes
  initSteps(['Select Frame', 'Configure', 'Preview', 'Export']);
  initEventListeners();
});

// Configurar escuchadores de eventos
function initEventListeners() {
  // Botón de selección de frame
  document.getElementById('select-frame-btn').addEventListener('click', () => {
    parent.postMessage({ 
      pluginMessage: { type: 'select-frame' } 
    }, '*');
  });
  
  // Escuchar mensajes del código principal
  window.onmessage = (event) => {
    const msg = event.data.pluginMessage;
    
    if (!msg) return;
    
    switch (msg.type) {
      case 'frame-selected':
        handleFrameSelected(msg);
        break;
      case 'error':
        showError(msg.message);
        break;
      // Otros tipos de mensajes...
    }
  };
}

// Manejar selección de frame
function handleFrameSelected(data) {
  // Mostrar el modal de configuración
  showModal({
    title: 'Configure Component',
    content: `
      <div class="form-group">
        <label for="component-type">Component Type:</label>
        <select id="component-type" class="select">
          <option value="button">Button</option>
          <option value="input">Input</option>
          <option value="card">Card</option>
          <option value="nav">Navigation</option>
          <!-- Más opciones... -->
        </select>
      </div>
      
      <div class="form-group">
        <label>Category:</label>
        <div class="radio-group">
          <label class="radio">
            <input type="radio" name="category" value="atom" checked>
            Atom
          </label>
          <label class="radio">
            <input type="radio" name="category" value="molecule">
            Molecule
          </label>
          <label class="radio">
            <input type="radio" name="category" value="organism">
            Organism
          </label>
        </div>
      </div>
    `,
    onConfirm: (modalElement) => {
      // Obtener valores seleccionados
      const componentType = modalElement.querySelector('#component-type').value;
      const category = modalElement.querySelector('input[name="category"]:checked').value;
      
      // Aquí procesaríamos estos datos y avanzaríamos al siguiente paso
      configureComponent(data, componentType, category);
    }
  });
}

// Configurar el componente seleccionado
function configureComponent(data, componentType, category) {
  console.log('Configuring component:', { data, componentType, category });
  
  // Actualizar el estado y pasar al siguiente paso
  // ...
  
  // Renderizar la vista previa
  renderPreview(data, componentType, category);
}

// Mostrar mensaje de error
function showError(message) {
  showModal({
    title: 'Error',
    content: `<p class="error-message">${message}</p>`,
    showCancel: false
  });
}
